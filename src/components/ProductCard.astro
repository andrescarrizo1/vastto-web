---
import { addAffiliateParam } from '../utils/affiliate';
import LazyImage from './LazyImage.astro';

interface Props {
  title: string;
  price: number;
  originalPrice?: number;
  image: string;
  url: string;
  badge?: string;
  rating?: number;
  reviews?: number;
  freeShipping?: boolean;
  verdict?: string;
  pros?: string[];
  cons?: string[];
}

const {
  title,
  price,
  originalPrice,
  image,
  url,
  badge,
  rating = 0,
  reviews = 0,
  freeShipping = false,
  verdict,
  pros = [],
  cons = [],
} = Astro.props;

const discount = originalPrice
  ? Math.round(((originalPrice - price) / originalPrice) * 100)
  : 0;

const formattedPrice = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  maximumFractionDigits: 0,
}).format(price);

const formattedOriginal = originalPrice
  ? new Intl.NumberFormat('es-AR', {
      style: 'currency',
      currency: 'ARS',
      maximumFractionDigits: 0,
    }).format(originalPrice)
  : null;

const affiliateUrl = addAffiliateParam(url);

// Generar JSON-LD estructurado para SEO
const validUntil = new Date();
validUntil.setFullYear(validUntil.getFullYear() + 1);
const validUntilStr = validUntil.toISOString().split('T')[0];

const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": new URL(image, Astro.site || Astro.url).toString(),
  "offers": {
    "@type": "Offer",
    "url": affiliateUrl,
    "priceCurrency": "ARS",
    "price": price,
    "priceValidUntil": validUntilStr,
    "itemCondition": "https://schema.org/NewCondition",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "VASTTO"
    }
  },
  ...(rating > 0 && reviews > 0 ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": rating,
      "reviewCount": reviews
    }
  } : {})
};
---

<article class="product-card">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  {badge && <span class="badge">{badge}</span>}
  <a href={affiliateUrl} target="_blank" rel="noopener sponsored" class="card-link">
    <div class="card-image">
      <LazyImage src={image} alt={title} class="card-img" />
    </div>
    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      {rating > 0 && (
        <div class="rating">
          <span class="stars">{'★'.repeat(Math.round(rating))}</span>
          <span class="reviews">({reviews})</span>
        </div>
      )}
      <div class="card-pricing">
        {formattedOriginal && (
          <span class="original-price">{formattedOriginal}</span>
        )}
        <span class="price">{formattedPrice}</span>
        {discount > 0 && (
          <span class="discount">-{discount}% OFF</span>
        )}
      </div>
      {freeShipping && (
        <span class="free-shipping">&#10003; Envio gratis</span>
      )}
      
      {verdict && (
        <div class="vastto-verdict">
          <h4>Veredicto VASTTO</h4>
          <p>{verdict}</p>
          {(pros.length > 0 || cons.length > 0) && (
            <div class="pros-cons">
              {pros && pros.length > 0 && (
                <div class="pros">
                  <ul>
                    {pros.map((pro: string) => <li><span class="icon">✓</span> {pro}</li>)}
                  </ul>
                </div>
              )}
              {cons && cons.length > 0 && (
                <div class="cons">
                  <ul>
                    {cons.map((con: string) => <li><span class="icon">✕</span> {con}</li>)}
                  </ul>
                </div>
              )}
            </div>
          )}
        </div>
      )}
      
      <div class="calc-hint">
        <a href="/herramientas/calculadora-cuotas">🧮 ¿Conviene en cuotas? Calculalo acá</a>
      </div>
      
      <button class="btn-buy">Ver Oferta en ML</button>
    </div>
  </a>
</article>

<style>
  .product-card {
    background: var(--vastto-surface);
    border-radius: 12px;
    border: 1px solid var(--vastto-border);
    padding: 1.5rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: 0 4px 15px var(--vastto-shadow);
  }
  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px var(--vastto-shadow);
    border-color: var(--vastto-border-hover);
  }
  .product-card:hover .btn-buy {
    background: #5535e0;
    box-shadow: 0 4px 12px rgba(108, 71, 255, 0.3);
  }
  .product-card:hover .card-image img {
    transform: scale(1.05);
  }
  .badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--text-main);
    color: var(--vastto-bg);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    z-index: 10;
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .card-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--vastto-surface);
    padding: 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.02);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }
  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    background: var(--vastto-surface);
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 800;
    margin: 0 0 1rem;
    line-height: 1.3;
    color: var(--text-main);
  }
  .rating {
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
  }
  .stars { color: #f59e0b; letter-spacing: 1px; }
  .reviews { color: var(--text-light); margin-left: 6px; font-weight: 500; }
  .price-section {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--vastto-border);
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .current-price {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text-main);
  }
  .original-price {
    font-size: 1rem;
    text-decoration: line-through;
    color: var(--text-light);
  }
  .discount {
    color: var(--vastto-green);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .free-shipping {
    color: var(--vastto-green);
    font-size: 0.85rem;
    font-weight: 600;
    display: block;
    margin-top: 0.25rem;
  }
  .btn-buy {
    width: 100%;
    background: #6c47ff;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: auto;
    min-height: 44px; /* CSS Placeholder */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .vastto-verdict {
    background: var(--vastto-bg-alt);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
    border-left: 3px solid #6c47ff;
    font-size: 0.85rem;
  }
  
  .vastto-verdict h4 {
    margin: 0 0 0.5rem 0;
    color: var(--text-main);
    font-size: 0.9rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  .vastto-verdict p {
    margin: 0 0 0.75rem 0;
    color: var(--text-body);
    line-height: 1.4;
  }
  
  .pros-cons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .pros, .cons {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  
  .pros li {
    color: #10b981;
    margin-bottom: 2px;
  }
  
  .cons li {
    color: #ef4444;
    margin-bottom: 2px;
  }
  
  .calc-hint {
    text-align: center;
    margin-bottom: 0.75rem;
  }
  
  .calc-hint a {
    color: #6c47ff;
    font-size: 0.85rem;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }
  
  .calc-hint a:hover {
    color: #3b1fa8;
    text-decoration: underline;
  }
</style>
