---
interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className = '' } = Astro.props;
const placeholder = '/images/placeholder.jpg'; // We need this image
---

<img 
  src={src} 
  alt={alt} 
  class={className}
  loading="lazy"
  decoding="async"
  width="400"
  height="400"
  style="max-width: 100%; height: auto; aspect-ratio: 1;"
  onerror={`this.onerror=null; this.src='${placeholder}';`}
/>
