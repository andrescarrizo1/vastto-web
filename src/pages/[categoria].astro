const data = categoryData[categoria as string];
const pageTitle = data?.title || `${categoria} | VASTTO`;
const pageDescription = data?.description || `Mejores productos en ${categoria}`;
const products = data?.products || [];

const validUntil = new Date();
validUntil.setFullYear(validUntil.getFullYear() + 1);
const validUntilStr = validUntil.toISOString().split('T')[0];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": products.map((prod, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": prod.title,
      "image": `https://vastto.com.ar${prod.image}`,
      "offers": {
        "@type": "Offer",
        "priceCurrency": "ARS",
        "price": prod.price,
        "priceValidUntil": validUntilStr,
        "availability": "https://schema.org/InStock"
      }
    }
  }))
});

let faqSchemaStr = "";
let currentFaqs: {q: string, a: string}[] = [];

if (categoria === 'auriculares') {
  currentFaqs = [
    { q: "¿Qué auriculares bluetooth comprar en 2026?", a: "Depende de tu uso. Si viajas mucho en transporte público, prioriza modelos in-ear u over-ear con buen aislamiento pasivo como los Sony WH-CH520." },
    { q: "¿Vale la pena la cancelación de ruido (ANC)?", a: "Sí, pero en modelos económicos (menos de $50.000 ARS) suele ser muy básica. Es mejor un auricular con buenas gomitas de silicona que un ANC de mala calidad." }
  ];
} else if (categoria === 'celulares') {
  currentFaqs = [
    { q: "¿Cuál es el mejor celular calidad/precio en Argentina?", a: "Actualmente, la serie Galaxy A de Samsung (como el A15 o A55) y la serie Redmi Note de Xiaomi dominan la gama media por sus pantallas AMOLED y actualizaciones garantizadas." },
    { q: "¿Es seguro comprar celulares por Mercado Libre?", a: "Sí, siempre y cuando elijas publicaciones marcadas como 'Full' (enviadas por ML) y de vendedores con reputación verde o tiendas oficiales." }
  ];
} else if (categoria === 'smartwatch') {
  currentFaqs = [
    { q: "¿Qué smartwatch es compatible con iPhone?", a: "Además del Apple Watch (la mejor opción integrada), los relojes Garmin y Amazfit funcionan excelente en iOS a través de sus propias apps." },
    { q: "¿Cuánto dura la batería de un smartwatch?", a: "Depende del sistema. Relojes con WearOS o WatchOS apenas duran 1-2 días, mientras que las pulseras deportivas (como Xiaomi Band o Amazfit) pueden superar los 14 días sin cargar." }
  ];
} else if (categoria === 'accesorios') {
  currentFaqs = [
    { q: "¿Los cargadores genéricos dañan la batería del celular?", a: "Sí, los cargadores sin certificación pueden no regular bien el voltaje. Recomendamos siempre comprar cargadores originales (Samsung, Apple) o marcas certificadas (Baseus, Ugreen)." }
  ];
}

if (currentFaqs.length > 0) {
  faqSchemaStr = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": currentFaqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  });
}
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={schema} />
  <section class="category-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a> &rsaquo;
        <span>{categoria}</span>
      </nav>
      <h1>Los Mejores {categoria?.charAt(0).toUpperCase()}{categoria?.slice(1)} de Argentina</h1>
      <p>{pageDescription}</p>
    </div>
  </section>

  <section class="products-section">
    <div class="container">
      <div class="products-header">
        <p>{products.length} productos encontrados</p>
        <span class="affiliate-note">* Precios sujetos a variaciones diarias. Consultar disponibilidad para precio final.</span>
      </div>
      <div class="products-grid">
        {products.map((product: any) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
    
    {currentFaqs.length > 0 && (
      <div class="faq-section">
        <h3>Preguntas Frecuentes sobre {categoria}</h3>
        <div class="faq-list">
          {currentFaqs.map(faq => (
            <details class="faq-item">
              <summary>
                {faq.q}
                <span class="icon">+</span>
              </summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    )}
  </section>
  {faqSchemaStr && <script type="application/ld+json" set:html={faqSchemaStr} />}
</Layout>

<style>
  .category-hero {
    background: linear-gradient(135deg, #1a0a3e 0%, #3b1fa8 50%, #6c47ff 100%);
    padding: 4rem 0;
    position: relative;
    overflow: hidden;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }
  .breadcrumb {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .breadcrumb a {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .breadcrumb a:hover { color: #fff; text-decoration: underline; }
  .category-hero h1 {
    font-size: 2.75rem;
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.5px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .category-hero p {
    color: rgba(255,255,255,0.85);
    font-size: 1.15rem;
    font-weight: 500;
    max-width: 800px;
    line-height: 1.5;
  }
  .products-section {
    padding: 4rem 0 6rem;
    background: var(--vastto-surface);
  }
  .products-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid rgba(0,0,0,0.03);
  }
  .products-header p {
    font-weight: 700;
    color: var(--text-main);
    font-size: 1.1rem;
  }
  .affiliate-note {
    font-size: 0.85rem;
    color: var(--text-light);
    font-style: italic;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  
  .faq-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--vastto-border);
  }
  .faq-section h3 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: var(--text-main);
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 800px;
  }
  .faq-item {
    background: var(--vastto-surface-alt);
    border: 1px solid var(--vastto-border);
    border-radius: 8px;
    overflow: hidden;
  }
  .faq-item summary {
    padding: 1.25rem;
    font-weight: 700;
    color: #3b1fa8;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item p {
    padding: 0 1.25rem 1.25rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
  }
  .faq-item[open] summary .icon {
    transform: rotate(45deg);
  }
  .icon {
    font-size: 1.5rem;
    transition: transform 0.2s ease;
    color: #6c47ff;
  }
  
  @media (max-width: 768px) {
    .category-hero { padding: 3rem 0; }
    .category-hero h1 { font-size: 2rem; }
    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .products-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>
