---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const featuredProducts = [
  {
    title: 'Samsung Galaxy A55 5G 128GB',
    price: 476717,
    originalPrice: 529900,
    image: '/images/samsung-galaxy-a55-5g-128gb.jpg',
    url: 'https://www.mercadolibre.com.ar/samsung-galaxy-a55-5g-128-gb-azul-increible-8-gb-ram/p/MLA32205562',
    badge: '🏆 TOP CELULAR',
    rating: 4.9,
    reviews: 876,
    freeShipping: true,
    verdict: 'El mejor equilibrio gama media. Pantalla Super AMOLED, 4 años de actualizaciones y diseño premium.',
    pros: ['Pantalla Super AMOLED 120Hz', '4 años de actualizaciones', 'Diseño idéntico al S24'],
    cons: ['Carga lenta de 25W'],
  },
  {
    title: 'Xiaomi Redmi Buds 6 Play - Negro',
    price: 29999,
    originalPrice: 45000,
    image: '/images/xiaomi-redmi-buds-6-play---negro.jpg',
    url: 'https://www.mercadolibre.com.ar/auriculares-inalambricos-xiaomi-redmi-buds-6-play-negro/p/MLA39962085',
    badge: 'MÁS VENDIDO',
    rating: 5,
    reviews: 6189,
    freeShipping: true,
    verdict: 'Ideales si buscás tu primer auricular TWS sin gastar de más. Batería interminable.',
    pros: ['Batería de 36 horas', 'Súper livianos', 'Conexión estable'],
    cons: ['Sin cancelación activa de ruido'],
  },
  {
    title: 'Xiaomi Redmi Watch 4 - Negro GPS',
    price: 89999,
    originalPrice: 120000,
    image: '/images/xiaomi-redmi-watch-4---negro-gps.jpg',
    url: 'https://www.mercadolibre.com.ar/smartwatch-xiaomi-redmi-watch-4-negro-197-gps/p/MLA29165243',
    badge: 'TOP SMARTWATCH',
    rating: 4.8,
    reviews: 1542,
    freeShipping: true,
    verdict: 'Pantalla gigante, GPS y 20 días de batería por menos de $90k. Imbatible.',
    pros: ['Pantalla 1.97"', 'GPS integrado', 'Batería 20 días'],
    cons: ['Correas propietarias'],
  },
  {
    title: 'HyperX Cloud Stinger 2 Core - Black',
    price: 39999,
    originalPrice: 59999,
    image: '/images/hyperx-cloud-stinger-2-core---black.jpg',
    url: 'https://www.mercadolibre.com.ar/auriculares-gamer-hyperx-cloud-stinger-2/p/MLA26547398',
    badge: 'GAMER',
    rating: 5,
    reviews: 1125,
    freeShipping: true,
    verdict: 'El auricular gamer honesto. No deslumbra en nada pero cumple en todo.',
    pros: ['Micrófono que mutea al levantarlo', 'Copas cómodas'],
    cons: ['Armazón de plástico'],
  },
  {
    title: 'Motorola Moto Edge 50 Fusion 256GB',
    price: 699999,
    originalPrice: 849999,
    image: '/images/motorola-moto-edge-50-fusion-256gb.jpg',
    url: 'https://www.mercadolibre.com.ar/motorola-moto-edge-50-fusion-256-gb-azul-artico-8-gb-ram/p/MLA36934442',
    badge: 'PREMIUM',
    rating: 5,
    reviews: 154,
    freeShipping: true,
    verdict: 'El celular más lindo por este precio. Carga turbo 68W y resistente al agua.',
    pros: ['Diseño premium', 'Carga 68W', 'IP68'],
    cons: ['Pantalla curva puede incomodar'],
  },
  {
    title: 'Cargador Samsung Original 25W',
    price: 28321,
    originalPrice: 35000,
    image: '/images/cargador-samsung-original-25w.jpg',
    url: 'https://www.mercadolibre.com.ar/cargador-samsung-25w-sin-cable-original/p/MLA12563214',
    badge: 'ESENCIAL',
    rating: 5,
    reviews: 670,
    freeShipping: true,
    verdict: 'Indispensable si tenés un Galaxy. Carga rápida sin dañar la batería.',
    pros: ['Carga Super Fast nativa', 'Protección contra sobrecarga'],
    cons: ['Sin cable incluido'],
  },
];

const categories = [
  { name: 'Auriculares', icon: '🎧', href: '/auriculares', count: 'Bluetooth, In-Ear, Gamer' },
  { name: 'Celulares', icon: '📱', href: '/celulares', count: 'Samsung, Motorola, Xiaomi' },
  { name: 'Smartwatch', icon: '⌚', href: '/smartwatch', count: 'Relojes y Pulseras' },
  { name: 'Accesorios', icon: '🔌', href: '/accesorios', count: 'Cargadores, Fundas, Gadgets' },
];

const guides = [
  { title: 'Top 5 Auriculares Bluetooth Baratos', href: '/auriculares/mejores-bluetooth-baratos', tag: 'Auriculares', desc: 'Redmi Buds, JBL y Sony. Opciones que sí valen la pena por menos de $90k.' },
  { title: 'JBL 510BT vs Sony WH-CH520', href: '/auriculares/jbl-tune-520bt-vs-sony-wh-ch520', tag: 'Comparativa', desc: 'Los 2 modelos over-ear más vendidos de Argentina, frente a frente.' },
  { title: 'Mejor Celular Gama Media Argentina 2026', href: '/guias/mejor-celular-gama-media-argentina', tag: 'Celulares', desc: '¿Samsung, Motorola o Xiaomi? Top 5 con precios reales.' },
  { title: 'Setup Gamer Barato que Funciona', href: '/guias/auriculares-gamer-baratos-argentina', tag: 'Gaming', desc: 'Auriculares + mouse + teclado por menos de $165k.' },
  { title: 'Smartwatch Baratos Menos de $100k', href: '/guias/mejores-smartwatch-baratos-argentina', tag: 'Smartwatch', desc: 'Huawei Band, Amazfit, Xiaomi. Los 5 mejores por poca plata.' },
  { title: 'Accesorios Indispensables para tu Celular', href: '/guias/mejores-accesorios-celular-indispensables', tag: 'Accesorios', desc: 'Cargadores, fundas y gadgets que se pagan solos.' },
];

const validUntil = new Date();
validUntil.setFullYear(validUntil.getFullYear() + 1);
const validUntilStr = validUntil.toISOString().split('T')[0];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": featuredProducts.map((prod, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": prod.title,
      "image": `https://vastto.com.ar${prod.image}`,
      "offers": {
        "@type": "Offer",
        "priceCurrency": "ARS",
        "price": prod.price,
        "priceValidUntil": validUntilStr,
        "availability": "https://schema.org/InStock"
      }
    }
  }))
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Qué es VASTTO?", "acceptedAnswer": { "@type": "Answer", "text": "VASTTO es un sitio argentino independiente de guías de compra y comparativas de tecnología. Analizamos celulares, auriculares, smartwatch y accesorios disponibles en Mercado Libre para ayudarte a comprar inteligente sin tirar la plata." } },
    { "@type": "Question", "name": "¿Los precios de VASTTO son reales?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, todos los precios que mostramos son de publicaciones reales de Mercado Libre Argentina. Como los precios cambian diariamente, siempre hacé click en 'Ver Oferta en ML' para ver el precio final actualizado." } },
    { "@type": "Question", "name": "¿VASTTO es una tienda?", "acceptedAnswer": { "@type": "Answer", "text": "No, VASTTO no vende productos. Somos un sitio de comparación y análisis independiente. Cuando hacés click en un producto, te redirigimos a Mercado Libre donde podés comprar con total seguridad y respaldo de compra protegida." } }
  ]
});
---
<Layout title="VASTTO — Guías de Compra de Tecnología en Argentina 2026" description="Guías de compra, comparativas y las mejores ofertas de celulares, auriculares y smartwatch en Argentina. No somos tienda, somos tu filtro inteligente en Mercado Libre.">
  <script type="application/ld+json" set:html={schema} />
  <script type="application/ld+json" set:html={faqSchema} />
  
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Tu Filtro Inteligente de Tecnología en Argentina</h1>
        <p>Guías de compra honestas, comparativas reales y productos verificados en Mercado Libre. Analizamos pros, contras y precios para que no tires la plata.</p>
        <a href="/guias" class="btn-hero">Leer Guías de Compra</a>
      </div>
    </div>
  </section>

  <!-- ÚLTIMAS GUÍAS - Sección principal para SEO -->
  <section class="guides-section">
    <div class="container">
      <div class="section-header">
        <h2>Guías de Compra 2026</h2>
        <p>Análisis honestos para comprar inteligente en Argentina</p>
      </div>
      <div class="guides-grid">
        {guides.map((guide) => (
          <a href={guide.href} class="guide-card-mini">
            <span class="guide-tag">{guide.tag}</span>
            <h3>{guide.title}</h3>
            <p>{guide.desc}</p>
            <span class="guide-cta">Leer Guía →</span>
          </a>
        ))}
      </div>
      <div class="guides-cta">
        <a href="/guias" class="btn-secondary">Ver Todas las Guías →</a>
      </div>
    </div>
  </section>

  <!-- CATEGORIAS -->
  <section class="categories">
    <div class="container">
      <h2>Explorar por Categoría</h2>
      <div class="categories-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="category-card">
            <span class="cat-icon">{cat.icon}</span>
            <span class="cat-name">{cat.name}</span>
            <span class="cat-count">{cat.count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCTOS DESTACADOS (reducido a 6) -->
  <section class="featured">
    <div class="container">
      <div class="section-header">
        <h2>Productos Destacados</h2>
        <p>Selección curada de los mejores productos con los mejores precios hoy</p>
      </div>
      <div class="products-grid">
        {featuredProducts.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUE VASTTO -->
  <section class="why-us">
    <div class="container">
      <h2>¿Por qué usar VASTTO?</h2>
      <div class="features-grid">
        <div class="feature">
          <span class="feature-icon">🔍</span>
          <h3>Guías Honestas</h3>
          <p>Analizamos pros y contras reales. No escondemos los defectos de los productos que recomendamos.</p>
        </div>
        <div class="feature">
          <span class="feature-icon">🇦🇷</span>
          <h3>100% Argentina</h3>
          <p>Precios en pesos, productos disponibles en Mercado Libre con envío Full a todo el país.</p>
        </div>
        <div class="feature">
          <span class="feature-icon">🛒</span>
          <h3>Compra Segura</h3>
          <p>Te llevamos directo a Mercado Libre. Comprás con toda la protección y garantía de ML.</p>
        </div>
        <div class="feature">
          <span class="feature-icon">★</span>
          <h3>Solo lo Mejor</h3>
          <p>Descartamos marcas sin soporte y productos sin reseñas. Solo mostramos lo que realmente vale la pena.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-home">
    <div class="container">
      <h2>Preguntas Frecuentes</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>¿Qué es VASTTO?<span class="icon">+</span></summary>
          <p>VASTTO es un sitio argentino independiente de guías de compra y comparativas de tecnología. Analizamos celulares, auriculares, smartwatch y accesorios disponibles en Mercado Libre para ayudarte a comprar inteligente.</p>
        </details>
        <details class="faq-item">
          <summary>¿Los precios son reales?<span class="icon">+</span></summary>
          <p>Sí, todos los precios son de publicaciones reales de Mercado Libre Argentina. Como cambian diariamente, siempre hacé click en "Ver Oferta en ML" para el precio final.</p>
        </details>
        <details class="faq-item">
          <summary>¿VASTTO es una tienda?<span class="icon">+</span></summary>
          <p>No, no vendemos productos. Somos un sitio de comparación independiente. Cuando hacés click, te redirigimos a Mercado Libre donde comprás con total seguridad.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="seo-content-section" id="guia-compra">
    <div class="container">
      <h2>Guía de Compra: Cómo Elegir Tecnología en Argentina 2026</h2>
      <div class="seo-grid">
        <div class="seo-item">
          <h3>Mejores Auriculares Bluetooth</h3>
          <p>Buscamos las mejores opciones en <strong>audio wireless</strong> comparando precios reales en Mercado Libre. Desde modelos gamer con baja latencia hasta auriculares con cancelación de ruido para estudiar o viajar. <a href="/guias/mejores-auriculares-aislantes-colectivo-argentina">Leer guía completa</a>.</p>
        </div>
        <div class="seo-item">
          <h3>Celulares Liberados y Garantía</h3>
          <p>Te mostramos los smartphones más vendidos con envío gratis en todo el país. Filtramos por pantalla, batería, cámara y rendimiento para que tu inversión valga la pena. <a href="/guias/mejor-celular-gama-media-argentina">Ver comparativa de gama media</a>.</p>
        </div>
        <div class="seo-item">
          <h3>Accesorios Tech Imprescindibles</h3>
          <p>No descuides la protección de tu equipo. Seleccionamos <strong>cargadores rápidos certificados</strong>, fundas de alta resistencia y gadgets que se pagan solos. <a href="/guias/mejores-accesorios-celular-indispensables">Ver accesorios recomendados</a>.</p>
        </div>
      </div>
      <p class="seo-footer-text">
        En <strong>VASTTO</strong> actualizamos nuestra selección diariamente para traerte las mejores oportunidades en tecnología. Nuestro análisis prioriza productos con las mejores reseñas de usuarios reales en Argentina.
      </p>
    </div>
  </section>

  <style>
    .seo-content-section {
      padding: 5rem 0;
      background: #fdfdfd;
      border-top: 1px solid #eee;
    }
    .seo-content-section h2 {
      font-size: 2rem;
      font-weight: 800;
      color: #1a1a1a;
      margin-bottom: 2.5rem;
      text-align: center;
    }
    .seo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2.5rem;
      margin-bottom: 3rem;
    }
    .seo-item h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #6c47ff;
      margin-bottom: 1rem;
    }
    .seo-item p {
      line-height: 1.6;
      color: #4a4a4a;
      font-size: 1rem;
    }
    .seo-item a {
      color: #6c47ff;
      font-weight: 600;
    }
    .seo-footer-text {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
      color: #888;
      font-size: 0.95rem;
      font-style: italic;
    }
    @media (max-width: 768px) {
      .seo-grid { gap: 1.5rem; }
    }
  </style>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #1a0a3e 0%, #3b1fa8 50%, #6c47ff 100%);
    padding: 6rem 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 1.25rem;
    line-height: 1.1;
    letter-spacing: -1px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .hero p {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    font-weight: 500;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .btn-hero {
    display: inline-block;
    background: #fff;
    color: #3b1fa8;
    text-decoration: none;
    padding: 1rem 2.5rem;
    border-radius: 12px;
    font-weight: 800;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 8px 25px rgba(0,0,0,0.25);
  }
  .btn-hero:hover { 
    background: #f0ebff; 
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.35);
  }

  /* GUIDES SECTION */
  .guides-section {
    padding: 5rem 0;
    background: #f8f7ff;
  }
  .section-header { margin-bottom: 2.5rem; text-align: center; }
  .section-header h2 { 
    font-size: 2.25rem; font-weight: 800; margin-bottom: 0.5rem; color: #1a1a1a; letter-spacing: -0.5px;
  }
  .section-header p { color: #666; font-size: 1.1rem; }
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .guide-card-mini {
    background: #fff;
    border-radius: 12px;
    padding: 1.75rem;
    text-decoration: none;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    transition: all 0.3s ease;
    display: block;
  }
  .guide-card-mini:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(108, 71, 255, 0.1);
    border-color: rgba(108, 71, 255, 0.2);
  }
  .guide-tag {
    background: rgba(108, 71, 255, 0.1);
    color: #6c47ff;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  .guide-card-mini h3 {
    font-size: 1.15rem;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
    font-weight: 800;
    line-height: 1.3;
  }
  .guide-card-mini p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 1rem;
  }
  .guide-cta {
    color: #6c47ff;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .guides-cta {
    text-align: center;
    margin-top: 2rem;
  }
  .btn-secondary {
    display: inline-block;
    background: #6c47ff;
    color: #fff;
    text-decoration: none;
    padding: 0.75rem 2rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.3s ease;
  }
  .btn-secondary:hover {
    background: #5535e0;
    transform: translateY(-2px);
  }

  .categories {
    padding: 5rem 0;
    background: #ffffff;
  }
  .categories h2, .featured h2, .why-us h2 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
    letter-spacing: -0.5px;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .category-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-align: center;
    border: 1px solid rgba(0,0,0,0.02);
  }
  .category-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    border-color: rgba(108, 71, 255, 0.15);
  }
  .cat-icon { 
    font-size: 3rem; 
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease;
  }
  .category-card:hover .cat-icon {
    transform: scale(1.1);
  }
  .cat-name { font-weight: 700; color: #1a1a1a; font-size: 1.1rem; }
  .cat-count { color: #666; font-size: 0.85rem; font-weight: 500; }
  .featured { padding: 5rem 0; background: #fff; }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  .why-us { padding: 5rem 0; background: #ffffff; border-top: 1px solid rgba(0,0,0,0.03); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .feature {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    text-align: center;
    transition: transform 0.3s ease;
  }
  .feature:hover {
    transform: translateY(-5px);
  }
  .feature-icon { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .feature h3 { font-size: 1.1rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.75rem; }
  .feature p { font-size: 0.95rem; color: #666; line-height: 1.5; }

  /* FAQ Home */
  .faq-home {
    padding: 5rem 0;
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.03);
  }
  .faq-home h2 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: #1a1a1a;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 800px;
  }
  .faq-item {
    background: #fdfdfd;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 8px;
    overflow: hidden;
  }
  .faq-item summary {
    padding: 1.25rem;
    font-weight: 700;
    color: #3b1fa8;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item p {
    padding: 0 1.25rem 1.25rem;
    color: #4a4a4a;
    line-height: 1.6;
