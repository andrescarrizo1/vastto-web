---
import Layout from '../../layouts/Layout.astro';

const guides = [
  {
    date: 'Marzo 2026',
    category: 'Auriculares',
    title: 'Top 5 Mejores Auriculares Bluetooth Baratos',
    description: 'Los 5 auriculares inalámbricos que realmente valen la pena por menos de $90.000. Redmi Buds, JBL y Sony.',
    href: '/auriculares/mejores-bluetooth-baratos',
  },
  {
    date: 'Marzo 2026',
    category: 'Review',
    title: 'Sony WH-CH520 Review: ¿Los más vendidos valen la pena?',
    description: 'Analizamos los Sony de $88.000. 50 horas de batería, micrófono espectacular y sonido equilibrado. Lo bueno y lo malo.',
    href: '/auriculares/sony-wh-ch520-review',
  },
  {
    date: 'Marzo 2026',
    category: 'Auriculares',
    title: 'Auriculares con Cancelación de Ruido (ANC) Baratos',
    description: 'Aislá el ruido del colectivo sin gastar $500.000. Las 3 opciones con ANC que podés comprar por menos de $80.000.',
    href: '/auriculares/mejores-cancelacion-ruido-baratos',
  },
  {
    date: 'Marzo 2026',
    category: 'Celulares',
    title: 'Mejor Celular Gama Media en Argentina 2026: Top 5 Comparativa',
    description: '¿Samsung, Motorola o Xiaomi? Comparamos los 5 mejores celulares gama media disponibles hoy en Argentina con precios reales de Mercado Libre.',
    href: '/celulares/mejor-celular-gama-media-argentina',
  },
  {
    date: 'Marzo 2026',
    category: 'Gaming',
    title: 'El Setup Gamer Más Barato que Funciona en Argentina',
    description: 'Auriculares HyperX, mouse Logitech G305 y teclado Redragon por menos de $165k. Setup completo que usan los pro players.',
    href: '/guias/auriculares-gamer-baratos-argentina',
  },
  {
    date: 'Marzo 2026',
    category: 'Smartwatch',
    title: 'Los 5 Mejores Smartwatch Baratos (Menos de $100k)',
    description: 'Huawei Band, Amazfit Bip, Xiaomi Redmi Watch y más. Los mejores relojes inteligentes baratos disponibles en Argentina hoy.',
    href: '/smartwatch/mejores-smartwatch-baratos-argentina',
  },
  {
    date: 'Marzo 2026',
    category: 'Accesorios',
    title: 'Los 6 Accesorios que tu Celular Necesita SÍ o SÍ',
    description: 'Cargadores originales, powerbank, fundas y gadgets que se pagan solos protegiendo tu inversión de $500k+.',
    href: '/guias/mejores-accesorios-celular-indispensables',
  },
];
---

<Layout title="Guías de Compra Tecnología Argentina 2026" description="Las mejores guías y comparativas de celulares, auriculares, smartwatch y accesorios en Argentina. Analizamos productos reales para que no tires la plata.">
  <section class="guides-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a> ›
        <span>Guías de Compra</span>
      </nav>
      <h1>Guías de Compra y Comparativas</h1>
      <p>Análisis honestos y directos para que no tires la plata comprando tecnología en Argentina. Todos los precios son de Mercado Libre.</p>
    </div>
  </section>

  <section class="guides-list">
    <div class="container">
      <div class="guides-grid">
        {guides.map(guide => (
          <a href={guide.href} class="guide-card">
            <div class="guide-content">
              <div class="guide-meta">
                <span class="guide-date">{guide.date}</span>
                <span class="guide-category">{guide.category}</span>
              </div>
              <h2>{guide.title}</h2>
              <p>{guide.description}</p>
              <span class="read-more">Leer Guía Completa →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .guides-hero {
    background: linear-gradient(135deg, #1a0a3e 0%, #3b1fa8 50%, #6c47ff 100%);
    padding: 4rem 0;
    position: relative;
    overflow: hidden;
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .breadcrumb {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .breadcrumb a {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: #fff; }
  .guides-hero h1 {
    font-size: 2.75rem;
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.5px;
  }
  .guides-hero p {
    color: rgba(255,255,255,0.85);
    font-size: 1.15rem;
    font-weight: 500;
  }
  
  .guides-list {
    padding: 5rem 0;
    background: var(--vastto-surface-alt);
  }
  .guides-grid {
    display: grid;
    gap: 2rem;
  }
  
  .guide-card {
    background: var(--vastto-surface);
    border-radius: 12px;
    padding: 2.5rem;
    text-decoration: none;
    border: 1px solid var(--vastto-border);
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    transition: all 0.3s ease;
    display: block;
  }
  
  .guide-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(108, 71, 255, 0.1);
    border-color: rgba(108, 71, 255, 0.2);
  }
  
  .guide-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .guide-date {
    font-size: 0.85rem;
    color: var(--text-light);
  }
  .guide-category {
    background: rgba(108, 71, 255, 0.1);
    color: #6c47ff;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .guide-card h2 {
    font-size: 1.75rem;
    color: var(--text-main);
    margin: 0 0 1rem;
    font-weight: 800;
    line-height: 1.3;
  }
  .guide-card p {
    color: var(--text-body);
    line-height: 1.6;
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }
  .read-more {
    color: #6c47ff;
    font-weight: 700;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .guides-hero h1 { font-size: 2rem; }
    .guide-card { padding: 1.5rem; }
    .guide-card h2 { font-size: 1.4rem; }
  }
</style>
